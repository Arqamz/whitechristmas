# ── WhiteChristmas Docker Environment ────────────────────────────────────────
# Copy this file to .env and fill in your values.
# docker-compose.yml uses these variables with sensible local defaults,
# so most settings only need to change if you're connecting to cloud services.

# ── Databases ─────────────────────────────────────────────────────────────────
# Leave unset (or blank) to use the local Postgres/MongoDB containers.
# Set to your cloud connection string to use an external DB instead.
POSTGRES_CONN_STRING=
MONGODB_CONN_STRING=

# ── Producer ──────────────────────────────────────────────────────────────────
# Total events per second across all four datasets (default: 40 = ~10/dataset)
PRODUCER_RATE=40

# ── Observability ─────────────────────────────────────────────────────────────
# Grafana admin password (default: whitechristmas)
GRAFANA_PASSWORD=whitechristmas
